{
  "rewrites": [
    {
      "source": "/article/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|facebookexternalhit|twitterbot|whatsapp|telegram|linkedinbot|slackbot|discordbot|googlebot|bingbot|applebot|ia_archiver|rogerbot|embedly|quora|outbrain|pinterest|vkshare|w3c_validator|showyoubot|flipboard|nuzzel|viber|skype|Line|MSNBot|DuckDuckBot|Baiduspider|YandexBot|Sogou|Exabot|facebot|ia_archiver).*"
        }
      ],
      "destination": "https://api.gallitify.tech/api/v1/articles/:slug"
    },
    {
      "source": "/category/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|facebookexternalhit|twitterbot|whatsapp|telegram|linkedinbot|slackbot|discordbot|googlebot|bingbot|applebot|ia_archiver|rogerbot|embedly|quora|outbrain|pinterest|vkshare|w3c_validator|showyoubot|flipboard|nuzzel|viber|skype|Line|MSNBot|DuckDuckBot|Baiduspider|YandexBot|Sogou|Exabot|facebot|ia_archiver).*"
        }
      ],
      "destination": "https://api.gallitify.tech/meta/category/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/og-default.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}

